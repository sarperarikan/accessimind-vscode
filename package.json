{
  "name": "accessimind",
  "displayName": "AccessiMind - AI WCAG Accessibility",
  "description": "AI-powered WCAG 2.2 accessibility analyzer with Gemini & Copilot integration. Real-time code improvement, Jira export, and comprehensive statistics.",
  "version": "1.1.5",
  "publisher": "sarperarikan",
  "icon": "accessi-mind.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/badge/WCAG-2.2-green",
      "href": "https://www.w3.org/WAI/WCAG22/quickref/",
      "description": "WCAG 2.2 Conformant"
    },
    {
      "url": "https://img.shields.io/badge/AI-Gemini%20%26%20Copilot-blue",
      "href": "https://github.com/sarperarikan/accessimind-vscode",
      "description": "AI Powered"
    }
  ],
  "homepage": "https://github.com/sarperarikan/accessimind-vscode",
  "bugs": {
    "url": "https://github.com/sarperarikan/accessimind-vscode/issues"
  },
  "preview": false,
  "pricing": "Free",
  "sponsor": {
    "url": "https://github.com/sponsors/sarperarikan"
  },
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarperarikan/accessimind-vscode.git"
  },
  "author": {
    "name": "Sarper Arıkan",
    "email": "sarperarikan@gmail.com"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Linters",
    "Other",
    "Machine Learning",
    "Testing"
  ],
  "keywords": [
    "wcag",
    "accessibility",
    "a11y",
    "aria",
    "gemini",
    "copilot",
    "ai",
    "wcag 2.2",
    "screen reader",
    "jira",
    "code analysis",
    "web accessibility"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:wcagEnhancer.showStatusBarMenu",
    "onCommand:wcagEnhancer.openChat",
    "onCommand:wcagEnhancer.inlineChat",
    "onCommand:wcagEnhancer.openSettings",
    "onCommand:wcagEnhancer.showInBrowser",
    "onCommand:wcagEnhancer.analyzeOpenCode",
    "onCommand:wcagEnhancer.analyzeSelectedCode",
    "onCommand:wcagEnhancer.startAgentSession",
    "onCommand:wcagEnhancer.selectProviderModel",
    "onCommand:wcagEnhancer.connectCodexAccount",
    "onCommand:wcagEnhancer.testCodexAccount",
    "onCommand:wcagEnhancer.openChatGptBridge",
    "onCommand:wcagEnhancer.configureChatGptAuth",
    "onCommand:wcagEnhancer.openChatGptAuthGuide"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wcagEnhancer.analyzeOpenCode",
        "title": "♿ AccessiMind: Analyze Open File",
        "icon": "$(search)"
      },
      {
        "command": "wcagEnhancer.analyzeSelectedCode",
        "title": "♿ AccessiMind: Analyze Selection",
        "icon": "$(selection)"
      },
      {
        "command": "wcagEnhancer.previewImprovement",
        "title": "♿ AccessiMind: Preview Improvement",
        "icon": "$(diff)"
      },
      {
        "command": "wcagEnhancer.setApiKey",
        "title": "♿ AccessiMind: Set Gemini API Key",
        "icon": "$(key)"
      },
      {
        "command": "wcagEnhancer.testAIConnection",
        "title": "♿ AccessiMind: Test AI Connection",
        "icon": "$(plug)"
      },
      {
        "command": "wcagEnhancer.showWelcome",
        "title": "♿ AccessiMind: Welcome Guide",
        "icon": "$(home)"
      },
      {
        "command": "wcagEnhancer.showDetailedStatistics",
        "title": "♿ AccessiMind: Statistics",
        "icon": "$(graph)"
      },
      {
        "command": "wcagEnhancer.openSettings",
        "title": "♿ AccessiMind: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "wcagEnhancer.openHelp",
        "title": "♿ AccessiMind: Help & Documentation",
        "icon": "$(book)"
      },
      {
        "command": "wcagEnhancer.exportStatistics",
        "title": "♿ AccessiMind: Export Statistics",
        "icon": "$(export)"
      },
      {
        "command": "wcagEnhancer.resetStatistics",
        "title": "♿ AccessiMind: Reset Statistics",
        "icon": "$(trash)"
      },
      {
        "command": "wcagEnhancer.createJiraTask",
        "title": "♿ AccessiMind: Create Jira Task",
        "icon": "$(issues)"
      },
      {
        "command": "wcagEnhancer.showStatusBarMenu",
        "title": "♿ AccessiMind: Quick Menu",
        "icon": "$(menu)"
      },
      {
        "command": "wcagEnhancer.resetDailyStatistics",
        "title": "♿ AccessiMind: Reset Daily Stats"
      },
      {
        "command": "wcagEnhancer.resetMonthlyStatistics",
        "title": "♿ AccessiMind: Reset Monthly Stats"
      },
      {
        "command": "wcagEnhancer.resetYearlyStatistics",
        "title": "♿ AccessiMind: Reset Yearly Stats"
      },
      {
        "command": "wcagEnhancer.showModernStatsPanel",
        "title": "♿ AccessiMind: Modern Statistics Panel",
        "icon": "$(dashboard)"
      },
      {
        "command": "wcagEnhancer.showPeriodStatistics",
        "title": "♿ AccessiMind: Period Statistics"
      },
      {
        "command": "wcagEnhancer.exportPeriodStatistics",
        "title": "♿ AccessiMind: Export Period Statistics"
      },
      {
        "command": "wcagEnhancer.restoreSettings",
        "title": "♿ AccessiMind: Restore Settings"
      },
      {
        "command": "wcagEnhancer.exportSettings",
        "title": "♿ AccessiMind: Export Settings"
      },
      {
        "command": "wcagEnhancer.importSettings",
        "title": "♿ AccessiMind: Import Settings"
      },
      {
        "command": "wcagEnhancer.clearPersistedSettings",
        "title": "♿ AccessiMind: Clear Persistent Settings"
      },
      {
        "command": "wcagEnhancer.showSettingsStatus",
        "title": "♿ AccessiMind: Settings Status"
      },
      {
        "command": "wcagEnhancer.applyJsonSettings",
        "title": "♿ AccessiMind: Apply JSON Settings"
      },
      {
        "command": "wcagEnhancer.syncToJson",
        "title": "♿ AccessiMind: Sync to JSON"
      },
      {
        "command": "wcagEnhancer.showJsonPath",
        "title": "♿ AccessiMind: Show JSON Path"
      },
      {
        "command": "wcagEnhancer.showJsonStatus",
        "title": "♿ AccessiMind: JSON Status"
      },
      {
        "command": "wcagEnhancer.resetJsonFile",
        "title": "♿ AccessiMind: Reset JSON File"
      },
      {
        "command": "wcagEnhancer.validateJsonHealth",
        "title": "♿ AccessiMind: Validate JSON"
      },
      {
        "command": "wcagEnhancer.repairJsonFile",
        "title": "♿ AccessiMind: Repair JSON"
      },
      {
        "command": "wcagEnhancer.openChat",
        "title": "♿ AccessiMind: Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "wcagEnhancer.inlineChat",
        "title": "♿ AccessiMind: Inline Chat",
        "icon": "$(edit)"
      },
      {
        "command": "wcagEnhancer.showInBrowser",
        "title": "♿ AccessiMind: Show in Browser",
        "icon": "$(globe)"
      },
      {
        "command": "wcagEnhancer.userJourneyScan",
        "title": "♿ AccessiMind: User Journey Scan",
        "icon": "$(compass)"
      },
      {
        "command": "wcagEnhancer.domDiffRisk",
        "title": "♿ AccessiMind: DOM Diff Risk",
        "icon": "$(history)"
      },
      {
        "command": "wcagEnhancer.designTokenGuard",
        "title": "♿ AccessiMind: Design Token Guard",
        "icon": "$(symbol-color)"
      },
      {
        "command": "wcagEnhancer.componentMemory",
        "title": "♿ AccessiMind: Component Memory",
        "icon": "$(symbol-class)"
      },
      {
        "command": "wcagEnhancer.applyLastFixToSimilar",
        "title": "♿ AccessiMind: Apply Last Fix To Similar",
        "icon": "$(replace-all)"
      },
      {
        "command": "wcagEnhancer.generatePrSummary",
        "title": "♿ AccessiMind: Generate PR Summary",
        "icon": "$(notebook-template)"
      },
      {
        "command": "wcagEnhancer.regressionShield",
        "title": "♿ AccessiMind: Regression Shield",
        "icon": "$(shield)"
      },
      {
        "command": "wcagEnhancer.generateA11yTest",
        "title": "AccessiMind: Generate Accessibility Test",
        "icon": "$(beaker)"
      },
      {
        "command": "wcagEnhancer.startAgentSession",
        "title": "AccessiMind: Agent Session",
        "icon": "$(hubot)"
      },
      {
        "command": "wcagEnhancer.selectProviderModel",
        "title": "AccessiMind: Select Provider Model",
        "icon": "$(sparkle)"
      },
      {
        "command": "wcagEnhancer.connectCodexAccount",
        "title": "AccessiMind: Connect Codex Account",
        "icon": "$(account)"
      },
      {
        "command": "wcagEnhancer.testCodexAccount",
        "title": "AccessiMind: Test Codex Account",
        "icon": "$(plug)"
      },
      {
        "command": "wcagEnhancer.openChatGptBridge",
        "title": "AccessiMind: Open in ChatGPT",
        "icon": "$(link-external)"
      },
      {
        "command": "wcagEnhancer.configureChatGptAuth",
        "title": "AccessiMind: Configure ChatGPT Auth",
        "icon": "$(key)"
      },
      {
        "command": "wcagEnhancer.openChatGptAuthGuide",
        "title": "AccessiMind: ChatGPT Auth Guide",
        "icon": "$(book)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wcagEnhancer",
          "title": "♿ AccessiMind",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "wcagEnhancer": [
        {
          "type": "webview",
          "id": "wcagEnhancer.tabbedMainView",
          "name": "AccessiMind",
          "icon": "resources/icon.svg",
          "when": "true"
        },
        {
          "id": "wcagEnhancer.settingsView",
          "name": "Settings",
          "icon": "resources/icon.svg",
          "when": "true"
        },
        {
          "type": "webview",
          "id": "wcagEnhancer.statsView",
          "name": "Statistics",
          "icon": "resources/icon.svg",
          "when": "false"
        },
        {
          "type": "webview",
          "id": "wcagEnhancer.modernStatsView",
          "name": "Modern Statistics",
          "icon": "resources/icon.svg",
          "when": "false"
        },
        {
          "type": "webview",
          "id": "wcagEnhancer.chatView",
          "name": "AccessiMind Chat",
          "icon": "resources/icon.svg",
          "when": "true"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "wcagEnhancer.analyzeSelectedCode",
          "when": "editorHasSelection",
          "group": "1_modification@1"
        },
        {
          "command": "wcagEnhancer.previewImprovement",
          "when": "editorHasSelection",
          "group": "1_modification@2"
        },
        {
          "command": "wcagEnhancer.inlineChat",
          "when": "editorHasSelection",
          "group": "1_modification@3"
        },
        {
          "command": "wcagEnhancer.analyzeOpenCode",
          "group": "1_modification@4"
        },
        {
          "submenu": "wcagEnhancer.submenu",
          "group": "1_modification@9"
        }
      ],
      "wcagEnhancer.submenu": [
        {
          "command": "wcagEnhancer.analyzeOpenCode",
          "group": "1_analyze"
        },
        {
          "command": "wcagEnhancer.analyzeSelectedCode",
          "when": "editorHasSelection",
          "group": "1_analyze"
        },
        {
          "command": "wcagEnhancer.previewImprovement",
          "when": "editorHasSelection",
          "group": "1_analyze"
        },
        {
          "command": "wcagEnhancer.userJourneyScan",
          "group": "2_innovation"
        },
        {
          "command": "wcagEnhancer.startAgentSession",
          "group": "2_innovation@2"
        },
        {
          "command": "wcagEnhancer.generateA11yTest",
          "group": "2_innovation@3"
        },
        {
          "command": "wcagEnhancer.selectProviderModel",
          "group": "3_provider"
        },
        {
          "command": "wcagEnhancer.connectCodexAccount",
          "group": "3_provider@2"
        },
        {
          "command": "wcagEnhancer.testCodexAccount",
          "group": "3_provider@3"
        },
        {
          "command": "wcagEnhancer.openChatGptBridge",
          "group": "4_external"
        },
        {
          "command": "wcagEnhancer.configureChatGptAuth",
          "group": "4_external@2"
        },
        {
          "command": "wcagEnhancer.openChatGptAuthGuide",
          "group": "4_external@3"
        }
      ]
    },
    "submenus": [
      {
        "id": "wcagEnhancer.submenu",
        "label": "♿ AccessiMind"
      }
    ],
    "keybindings": [
      {
        "command": "wcagEnhancer.analyzeOpenCode",
        "key": "ctrl+alt+w",
        "when": "editorTextFocus"
      },
      {
        "command": "wcagEnhancer.analyzeSelectedCode",
        "key": "ctrl+alt+shift+w",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AccessiMind",
      "description": "All settings are managed through the extension UI. Please use the Settings panel in the AccessiMind sidebar.",
      "properties": {
        "wcagEnhancer.ai": {
          "type": "object",
          "title": "AI Configuration",
          "description": "All AI provider and model settings - Use the Settings panel to configure",
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "gemini",
                "vscode-copilot",
                "ollama",
                "codex-subscription"
              ],
              "default": "gemini",
              "description": "AI provider for WCAG improvements - Configure via Settings panel",
              "enumDescriptions": [
                "Google Gemini API (requires API key)",
                "VS Code Copilot (uses GitHub Copilot subscription)",
                "Ollama (Local AI models)",
                "Codex CLI using ChatGPT subscription sign-in"
              ]
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Your Gemini API key (only needed for Gemini provider) - Configure via Settings panel",
              "scope": "application"
            },
            "testConnection": {
              "type": "boolean",
              "default": true,
              "description": "Test AI connection when settings are changed - Configure via Settings panel"
            },
            "autoTestOnChange": {
              "type": "boolean",
              "default": true,
              "description": "Automatically test connection when API key or provider changes - Configure via Settings panel"
            },
            "ollamaUrl": {
              "type": "string",
              "default": "http://localhost:11434",
              "description": "Ollama API URL (default: http://localhost:11434)"
            },
            "ollamaModel": {
              "type": "string",
              "default": "llama3",
              "description": "Selected Ollama model"
            },
            "codexPath": {
              "type": "string",
              "default": "codex",
              "description": "Codex CLI executable path for ChatGPT subscription-backed analysis. Use codex by default, or set an absolute path if the app alias is blocked."
            },
            "codexTimeoutMs": {
              "type": "number",
              "default": 180000,
              "minimum": 30000,
              "maximum": 600000,
              "description": "Timeout in milliseconds for Codex subscription provider runs."
            }
          }
        },
        "wcagEnhancer.aiModels": {
          "type": "object",
          "title": "AI Model Configuration",
          "description": "AI model selection and preferences - Use the Settings panel to configure",
          "properties": {
            "selectedModel": {
              "type": "string",
              "default": "gemini-2.5-flash",
              "description": "Currently selected AI model - Configure via Settings panel",
              "enum": [
                "gpt-5.5",
                "gpt-5.4",
                "gpt-5.4-mini",
                "gpt-5.3-codex-spark",
                "gpt-5.2",
                "gpt-5.2-codex",
                "gemini-2.5-flash-lite",
                "gemini-3.1-flash-lite",
                "gemini-flash-latest",
                "gemini-3.5-flash",
                "gemini-3-flash",
                "gemini-3-pro",
                "gemini-2.5-flash",
                "gemini-2.5-pro",
                "gpt-4o",
                "gpt-4o-mini",
                "gpt-4.1",
                "gpt-5",
                "gpt-5-mini",
                "gpt-5.1-codex",
                "gpt-4",
                "gpt-3.5-turbo",
                "o3-mini",
                "o4-mini",
                "claude-3.5-sonnet",
                "claude-3.7-sonnet",
                "claude-4.5-sonnet",
                "claude-4.5-opus",
                "claude-3-opus",
                "claude-3-sonnet",
                "claude-3-haiku"
              ],
              "enumDescriptions": [
                "GPT-5.5 - Recommended Codex frontier model",
                "GPT-5.4 - Frontier Codex coding and reasoning model",
                "GPT-5.4 Mini - Faster Codex model for lighter tasks",
                "GPT-5.3 Codex Spark - Pro research preview for near-instant coding iteration",
                "GPT-5.2 - Latest general",
                "GPT-5.2 Codex - Latest code-optimized",
                "Gemini 2.5 Flash-Lite - Fast and budget-friendly 2.5 family",
                "Gemini 3.1 Flash-Lite - Cost-efficient Gemini 3 series",
                "Gemini Flash Latest - Dynamic alias for the latest Flash release",
                "Gemini 3.5 Flash - GA model for agentic and coding tasks",
                "Gemini 3 Flash - Next-gen multimodal",
                "Gemini 3 Pro - Higher quality",
                "Gemini 2.5 Flash - Fastest response time",
                "Gemini 2.5 Pro - Highest quality",
                "GPT-4o - Latest OpenAI model",
                "GPT-4o Mini - Fast and efficient",
                "GPT-4.1 - High quality completions",
                "GPT-5 - Advanced reasoning",
                "GPT-5 Mini - Efficient variant",
                "GPT-5.1 Codex - Code-optimized",
                "GPT-4 - High quality responses",
                "GPT-3.5 Turbo - Fast and reliable",
                "OpenAI o3 Mini - Low latency",
                "OpenAI o4 Mini - Efficient",
                "Claude 3.5 Sonnet - Advanced reasoning",
                "Claude Sonnet 3.7 - Improved reasoning",
                "Claude Sonnet 4.5 - Latest sonnet",
                "Claude Opus 4.5 - Highest capability",
                "Claude 3 Opus - Most capable",
                "Claude 3 Sonnet - Balanced performance",
                "Claude 3 Haiku - Fast and efficient"
              ]
            },
            "enableGeminiModels": {
              "type": "boolean",
              "default": true,
              "description": "Enable Gemini models for selection - Configure via Settings panel"
            },
            "enableCopilotModels": {
              "type": "boolean",
              "default": true,
              "description": "Enable GitHub Copilot models for selection - Configure via Settings panel"
            },
            "autoSelectBestModel": {
              "type": "boolean",
              "default": false,
              "description": "Automatically select the best available model based on provider - Configure via Settings panel"
            },
            "preferFastModels": {
              "type": "boolean",
              "default": true,
              "description": "Prefer faster models over higher quality ones - Configure via Settings panel"
            },
            "modelPreferences": {
              "type": "object",
              "description": "Model preferences for different use cases - Configure via Settings panel",
              "properties": {
                "forQuickImprovements": {
                  "type": "string",
                  "default": "gemini-2.5-flash",
                  "description": "Model for quick WCAG improvements",
                  "enum": [
                    "gemini-2.5-flash",
                    "gpt-4o-mini",
                    "claude-3-haiku",
                    "gpt-3.5-turbo",
                    "gemini-3.5-flash",
                    "gemini-flash-latest",
                    "gemini-2.5-flash-lite"
                  ]
                },
                "forComplexAnalysis": {
                  "type": "string",
                  "default": "gemini-2.5-pro",
                  "description": "Model for complex WCAG analysis",
                  "enum": [
                    "gemini-2.5-pro",
                    "gpt-4o",
                    "claude-3.5-sonnet",
                    "claude-3-opus",
                    "gemini-3.5-flash"
                  ]
                }
              }
            }
          }
        },
        "wcagEnhancer.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "tr"
          ],
          "default": "en",
          "description": "Language for AI responses and interface - Configure via Settings panel",
          "enumDescriptions": [
            "Auto-detect from VS Code",
            "English",
            "Turkish"
          ]
        },
        "wcagEnhancer.wcagLevel": {
          "type": "string",
          "enum": [
            "A",
            "AA",
            "AAA"
          ],
          "default": "AA",
          "description": "Target WCAG conformance level - Configure via Settings panel",
          "enumDescriptions": [
            "Level A - Basic accessibility",
            "Level AA - Standard accessibility (Recommended)",
            "Level AAA - Enhanced accessibility"
          ]
        },
        "wcagEnhancer.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply improvements to code without confirmation - Configure via Settings panel"
        },
        "wcagEnhancer.includeComments": {
          "type": "boolean",
          "default": true,
          "description": "Include explanatory comments about WCAG improvements - Configure via Settings panel"
        },
        "wcagEnhancer.enableStatistics": {
          "type": "boolean",
          "default": true,
          "description": "Track usage statistics and metrics - Configure via Settings panel"
        },
        "wcagEnhancer.performance": {
          "type": "object",
          "title": "Performance",
          "description": "Performance-related settings",
          "properties": {
            "fastMode": {
              "type": "boolean",
              "default": true,
              "description": "Optimize prompts by compressing/truncating code before sending to AI"
            },
            "promptMaxChars": {
              "type": "number",
              "default": 8000,
              "minimum": 1000,
              "maximum": 200000,
              "description": "Maximum characters to include in AI prompts"
            },
            "maxScanSize": {
              "type": "number",
              "default": 500000,
              "minimum": 10000,
              "maximum": 5000000,
              "description": "Maximum characters to scan when extracting WCAG metadata from code"
            },
            "maxRegexMatches": {
              "type": "number",
              "default": 100,
              "minimum": 10,
              "maximum": 10000,
              "description": "Maximum number of regex matches to process per scan"
            },
            "backoffBaseMs": {
              "type": "number",
              "default": 1000,
              "minimum": 100,
              "maximum": 60000,
              "description": "Base delay for exponential backoff between retries"
            }
          }
        },
        "wcagEnhancer.shortcuts.analyzeOpenCode": {
          "type": "string",
          "default": "ctrl+alt+w",
          "description": "Keyboard shortcut to analyze open code structures - Configure via Settings panel",
          "scope": "window"
        },
        "wcagEnhancer.shortcuts.analyzeSelectedCode": {
          "type": "string",
          "default": "ctrl+alt+shift+w",
          "description": "Keyboard shortcut to analyze selected code - Configure via Settings panel",
          "scope": "window"
        },
        "wcagEnhancer.shortcuts.showInterface": {
          "type": "string",
          "default": "ctrl+alt+u",
          "description": "Keyboard shortcut to show statistics interface - Configure via Settings panel",
          "scope": "window"
        },
        "wcagEnhancer.customPrompt": {
          "type": "string",
          "default": "",
          "description": "Custom prompt for WCAG improvements (optional) - Configure via Settings panel"
        },
        "wcagEnhancer.responseDetail": {
          "type": "string",
          "default": "summary",
          "enum": [
            "summary",
            "detailed"
          ],
          "description": "Level of detail for AI responses (summary or detailed) - Configure via Settings panel"
        },
