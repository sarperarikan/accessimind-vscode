{
  "name": "accessimind",
  "displayName": "AccessiMind",
  "description": "AI-powered WCAG 2.2 accessibility improvements with real-time statistics",
  "version": "1.0.0",
  "publisher": "sarperarikan",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarperarikan/wcag-enhancer.git"
  },
  "author": {
    "name": "Sarper Arıkan",
    "email": "sarperarikan@gmail.com"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Formatters",
    "Machine Learning"
  ],
  "keywords": [
    "wcag",
    "accessibility",
    "aria",
    "gemini",
    "ai",
    "assistant",
    "a11y"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wcagEnhancer.analyzeOpenCode",
        "title": "AccessiMind: Analyze Open Code Structures",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.analyzeSelectedCode",
        "title": "AccessiMind: Analyze Selected Code",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.setApiKey",
        "title": "AccessiMind: Set Gemini API Key",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.testAIConnection",
        "title": "AccessiMind: Test AI Connection",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.showWelcome",
        "title": "AccessiMind: Show Welcome Guide",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.showDetailedStatistics",
        "title": "AccessiMind: Show Detailed Statistics",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.exportStatistics",
        "title": "AccessiMind: Export Statistics",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.resetStatistics",
        "title": "AccessiMind: Reset Statistics",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.createJiraTask",
        "title": "AccessiMind: Create Jira Task",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.showStatusBarMenu",
        "title": "AccessiMind: Show Status Bar Menu",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.resetDailyStatistics",
        "title": "AccessiMind: Reset Daily Statistics",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.resetMonthlyStatistics",
        "title": "AccessiMind: Reset Monthly Statistics",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.resetYearlyStatistics",
        "title": "AccessiMind: Reset Yearly Statistics",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.showModernStatsPanel",
        "title": "AccessiMind: Show Modern Statistics Panel",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.showPeriodStatistics",
        "title": "AccessiMind: Show Period Statistics",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.exportPeriodStatistics",
        "title": "AccessiMind: Export Period Statistics",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.restoreSettings",
        "title": "AccessiMind: Restore Persistent Settings",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.exportSettings",
        "title": "AccessiMind: Export Settings",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.importSettings",
        "title": "AccessiMind: Import Settings",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.clearPersistedSettings",
        "title": "AccessiMind: Clear Persistent Settings",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.showSettingsStatus",
        "title": "AccessiMind: Show Settings Status",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.applyJsonSettings",
        "title": "AccessiMind: Apply JSON Settings to VS Code",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.syncToJson",
        "title": "AccessiMind: Sync VS Code Settings to JSON",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.showJsonPath",
        "title": "AccessiMind: Show JSON File Path",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.showJsonStatus",
        "title": "AccessiMind: Show JSON Status",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.resetJsonFile",
        "title": "AccessiMind: Reset JSON File",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.validateJsonHealth",
        "title": "AccessiMind: Validate JSON Health",
        "category": "AccessiMind"
      },
      {
        "command": "wcagEnhancer.repairJsonFile",
        "title": "AccessiMind: Repair JSON File",
        "category": "AccessiMind"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wcagEnhancer",
          "title": "♿ AccessiMind",
          "icon": "resources/icon.svg"
        }
      ]
    },
      "views": {
   "wcagEnhancer": [
    {
     "id": "wcagEnhancer.tabbedMainView",
     "name": "AccessiMind",
     "when": "true"
    },
				{
					"id": "wcagEnhancer.settingsView",
					"name": "Settings",
					"when": "true"
				},
				{
					"id": "wcagEnhancer.statsView",
					"name": "Statistics",
					"when": "false"
				},
				{
					"id": "wcagEnhancer.modernStatsView",
					"name": "Modern Statistics",
					"when": "false"
				}
			]
		},
    "menus": {
      "editor/context": [
        {
          "submenu": "wcagEnhancer.submenu",
          "group": "1_modification@1"
        }
      ],
      "wcagEnhancer.submenu": [
        {
          "command": "wcagEnhancer.analyzeOpenCode",
          "group": "1_analyze"
        },
        {
          "command": "wcagEnhancer.analyzeSelectedCode",
          "when": "editorHasSelection",
          "group": "1_analyze"
        }
      ]
    },
    "submenus": [
      {
        "id": "wcagEnhancer.submenu",
        "label": "♿ AccessiMind"
      }
    ],
    "keybindings": [
      {
        "command": "wcagEnhancer.analyzeOpenCode",
        "key": "ctrl+alt+w",
        "when": "editorTextFocus"
      },
      {
        "command": "wcagEnhancer.analyzeSelectedCode",
        "key": "ctrl+alt+shift+w",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AccessiMind",
      "description": "All settings are managed through the extension UI. Please use the Settings panel in the AccessiMind sidebar.",
      "properties": {
        "wcagEnhancer.ai": {
          "type": "object",
          "title": "AI Configuration",
          "description": "All AI provider and model settings - Use the Settings panel to configure",
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "gemini",
                "vscode-copilot"
              ],
              "default": "gemini",
              "description": "AI provider for WCAG improvements - Configure via Settings panel",
              "enumDescriptions": [
                "Google Gemini API (requires API key)",
                "VS Code Copilot (uses GitHub Copilot subscription)"
              ]
            },
            "apiKey": {
              "type": "string",
              "default": "",
              "description": "Your Gemini API key (only needed for Gemini provider) - Configure via Settings panel",
              "scope": "application"
            },
            "testConnection": {
              "type": "boolean",
              "default": true,
              "description": "Test AI connection when settings are changed - Configure via Settings panel"
            },
            "autoTestOnChange": {
              "type": "boolean",
              "default": true,
              "description": "Automatically test connection when API key or provider changes - Configure via Settings panel"
            }
          }
        },
        "wcagEnhancer.aiModels": {
          "type": "object",
          "title": "AI Model Configuration",
          "description": "AI model selection and preferences - Use the Settings panel to configure",
          "properties": {
            "selectedModel": {
              "type": "string",
              "default": "gemini-2.5-flash",
              "description": "Currently selected AI model - Configure via Settings panel",
              "enum": [
                "gemini-2.5-flash",
                "gemini-2.5-pro",
                "gpt-4o",
                "gpt-4o-mini",
                "gpt-4",
                "gpt-3.5-turbo",
                "claude-3.5-sonnet",
                "claude-3-opus",
                "claude-3-sonnet",
                "claude-3-haiku"
              ],
              "enumDescriptions": [
                "Gemini 2.5 Flash - Fastest response time",
                "Gemini 2.5 Pro - Highest quality",
                "GPT-4o - Latest OpenAI model",
                "GPT-4o Mini - Fast and efficient",
                "GPT-4 - High quality responses",
                "GPT-3.5 Turbo - Fast and reliable",
                "Claude 3.5 Sonnet - Advanced reasoning",
                "Claude 3 Opus - Most capable",
                "Claude 3 Sonnet - Balanced performance",
                "Claude 3 Haiku - Fast and efficient"
              ]
            },
            "enableGeminiModels": {
              "type": "boolean",
              "default": true,
              "description": "Enable Gemini models for selection - Configure via Settings panel"
            },
            "enableCopilotModels": {
              "type": "boolean",
              "default": true,
              "description": "Enable GitHub Copilot models for selection - Configure via Settings panel"
            },
            "autoSelectBestModel": {
              "type": "boolean",
              "default": false,
              "description": "Automatically select the best available model based on provider - Configure via Settings panel"
            },
            "preferFastModels": {
              "type": "boolean",
              "default": true,
              "description": "Prefer faster models over higher quality ones - Configure via Settings panel"
            },
            "modelPreferences": {
              "type": "object",
              "description": "Model preferences for different use cases - Configure via Settings panel",
              "properties": {
                "forQuickImprovements": {
                  "type": "string",
                  "default": "gemini-2.5-flash",
                  "description": "Model for quick WCAG improvements",
                  "enum": [
                    "gemini-2.5-flash",
                    "gpt-4o-mini",
                    "claude-3-haiku",
                    "gpt-3.5-turbo"
                  ]
                },
                "forComplexAnalysis": {
                  "type": "string",
                  "default": "gemini-2.5-pro",
                  "description": "Model for complex WCAG analysis",
                  "enum": [
                    "gemini-2.5-pro",
                    "gpt-4o",
                    "claude-3.5-sonnet",
                    "claude-3-opus"
                  ]
                }
              }
            }
          }
        },
        "wcagEnhancer.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "tr"
          ],
          "default": "en",
          "description": "Language for AI responses and interface - Configure via Settings panel",
          "enumDescriptions": [
            "Auto-detect from VS Code",
            "English",
            "Turkish"
          ]
        },
        "wcagEnhancer.wcagLevel": {
          "type": "string",
          "enum": [
            "A",
            "AA",
            "AAA"
          ],
          "default": "AA",
          "description": "Target WCAG compliance level - Configure via Settings panel",
          "enumDescriptions": [
            "Level A - Basic accessibility",
            "Level AA - Standard accessibility (Recommended)",
            "Level AAA - Enhanced accessibility"
          ]
        },
        "wcagEnhancer.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply improvements to code without confirmation - Configure via Settings panel"
        },
        "wcagEnhancer.includeComments": {
          "type": "boolean",
          "default": true,
          "description": "Include explanatory comments about WCAG improvements - Configure via Settings panel"
        },
        "wcagEnhancer.enableStatistics": {
          "type": "boolean",
          "default": true,
          "description": "Track usage statistics and metrics - Configure via Settings panel"
        },
        "wcagEnhancer.shortcuts.analyzeOpenCode": {
          "type": "string",
          "default": "ctrl+alt+w",
          "description": "Keyboard shortcut to analyze open code structures - Configure via Settings panel",
          "scope": "window"
        },
        "wcagEnhancer.shortcuts.analyzeSelectedCode": {
          "type": "string",
          "default": "ctrl+alt+shift+w",
          "description": "Keyboard shortcut to analyze selected code - Configure via Settings panel",
          "scope": "window"
        },
        "wcagEnhancer.shortcuts.showInterface": {
          "type": "string",
          "default": "ctrl+alt+u",
          "description": "Keyboard shortcut to show statistics interface - Configure via Settings panel",
          "scope": "window"
        },
        "wcagEnhancer.customPrompt": {
          "type": "string",
          "default": "",
          "description": "Custom prompt for WCAG improvements (optional) - Configure via Settings panel"
        },
        "wcagEnhancer.responseDetail": {
          "type": "string",
          "default": "summary",
          "enum": ["summary", "detailed"],
          "description": "Level of detail for AI responses (summary or detailed) - Configure via Settings panel"
        },
        "wcagEnhancer.interfacePreferences": {
          "type": "object",
          "title": "Interface Preferences",
          "description": "Customize interface options such as theme, font size, and layout - Configure via Settings panel",
          "properties": {
            "theme": {
              "type": "string",
              "default": "auto",
              "enum": ["auto", "light", "dark"],
              "description": "Interface theme"
            },
            "fontSize": {
              "type": "string",
              "default": "medium",
              "enum": ["small", "medium", "large"],
              "description": "Font size for extension panels"
            }
          }
        },
        "wcagEnhancer.jira": {
          "type": "object",
          "title": "Jira Task Configuration",
          "description": "Configuration for WCAG Jira task creation - Configure via Settings panel",
          "properties": {
            "customPrompt": {
              "type": "string",
              "default": "",
              "description": "Custom prompt for Jira task generation (optional) - Configure via Settings panel"
            },
            "useCustomPrompt": {
              "type": "boolean",
              "default": false,
              "description": "Always ask for custom prompt when creating Jira tasks - Configure via Settings panel"
            },
            "defaultPriority": {
              "type": "string",
              "enum": [
                "Critical",
                "High",
                "Medium",
                "Low"
              ],
              "default": "Medium",
              "description": "Default priority for WCAG Jira tasks - Configure via Settings panel",
              "enumDescriptions": [
                "Critical - Blocks accessibility for many users",
                "High - Significant accessibility barrier",
                "Medium - Important accessibility improvement",
                "Low - Nice-to-have accessibility enhancement"
              ]
            },
            "defaultComponent": {
              "type": "string",
              "enum": [
                "images",
                "navigation",
                "forms",
                "color",
                "keyboard",
                "structure",
                "responsive",
                "media",
                "other"
              ],
              "default": "other",
              "description": "Default component/area for WCAG tasks - Configure via Settings panel",
              "enumDescriptions": [
                "Images & Media - Alt text, captions, audio descriptions",
                "Navigation & Links - Link text, skip links, breadcrumbs",
                "Forms & Input - Labels, validation, instructions",
                "Color & Contrast - Color contrast, color-only information",
                "Keyboard Access - Tab order, focus management",
                "Structure & Semantics - Headings, landmarks, ARIA",
                "Responsive & Mobile - Mobile accessibility, touch targets",
                "Audio & Video - Captions, transcripts, controls",
                "Other - General accessibility improvements"
              ]
            },
            "includeCodeExamples": {
              "type": "boolean",
              "default": true,
              "description": "Include code examples in Jira task descriptions - Configure via Settings panel"
            },
            "includeTestingSteps": {
              "type": "boolean",
              "default": true,
              "description": "Include testing steps in Jira task descriptions - Configure via Settings panel"
            }
          }
        },
        "wcagEnhancer.wizardCompleted": {
          "type": "boolean",
          "default": false,
          "description": "Whether the setup wizard has been completed - Configure via Settings panel"
        }
      }
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/jest": "^29.5.8",
    "@types/node": "18.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.4",
    "@vscode/vsce": "^2.22.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.47.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.1.6",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "webpack": "webpack",
    "webpack-dev": "webpack --mode development --watch",
    "webpack-prod": "cross-env NODE_ENV=production webpack --mode production",
    "build": "npm run webpack-prod",
    "package": "npm run build && vsce package",
    "package-dev": "npm run webpack-dev && vsce package",
    "clean": "rimraf out dist *.vsix",
    "rebuild": "npm run clean && npm run build"
  }
}
